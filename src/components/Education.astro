---
import Badge from "./ui/Badge.astro";
import Card from "./ui/Card.astro";
import TimeLine from "./TimeLine.astro";

const education = [
  {
    title: "Ingeniería - Desarrollo y Gestión de Software",
    university: "Universidad Tecnológica de Huejotzingo",
    period: "2023 – 2025",
    description: `Completé la ingeniería con un enfoque en metodologías ágiles, diseño y arquitectura de software, aplicando las mejores prácticas profesionales en cada etapa del desarrollo. Este programa fortaleció mis habilidades técnicas avanzadas, así como competencias blandas clave como pensamiento crítico, comunicación efectiva y resolución de problemas complejos en entornos colaborativos. Estoy preparado para liderar proyectos tecnológicos, impulsando soluciones innovadoras y eficientes en el sector`,
    current: true,
  },

  {
    title: "TSU - Desarrollo de Software Multiplataforma",
    university: "Universidad Tecnológica de Huejotzingo",
    period: "2021 – 2023",
    description: `Durante este programa técnico superior universitario, adquirí una sólida base en programación orientada a objetos, diseño y gestión de bases de datos, así como en redes de computadoras. Además, profundicé en el desarrollo de aplicaciones tanto web como móviles, empleando tecnologías modernas que me permitieron comprender el ciclo completo del desarrollo de software y sentar las bases para mi carrera profesional en el área tecnológica.`,
    current: true,
  },
];
---

<TimeLine>
  {
    education.map((edc) => (
      <div class="relative pl-12 md:pl-24  ">
        <div class="absolute left-2.5 md:left-6.5 top-0 flex items-center justify-center">
          {edc.current ? (
            <span class="relative flex size-4">
              <span class="absolute inline-flex h-full w-full rounded-full bg-primary ring-4 ring-primary/20 animate-ping" />
              <span class="relative inline-flex size-4 rounded-full bg-primary ring-4 ring-primary/20" />
            </span>
          ) : (
            <div class="size-4 rounded-full bg-primary ring-4 ring-primary/20" />
          )}
        </div>
        <Card class="p-6">
          <div class="flex flex-col md:flex-row md:items-center justify-between mb-4 gap-2 ">
            <div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white leading-none">
                {edc.title}
              </h3>
              <p class="text-primary font-semibold mt-1">{edc.university}</p>
            </div>
            <Badge>{edc.period}</Badge>
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed whitespace-pre-line">
            {edc.description}
          </p>
        </Card>
      </div>
    ))
  }
</TimeLine>
