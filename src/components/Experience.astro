---
import TimeLine from "./TimeLine.astro";
import Badge from "./ui/Badge.astro";
import Card from "./ui/Card.astro";

const experiences = [
  {
    title: "Plataforma web de Cursos - Versión Completa",
    company: "Freelance",
    period: "Enero 2026 - Marzo 2026",
    description: `Desarrollé una plataforma web de cursos utilizando Angular y Laravel. Implementé autenticación, panel de usuario, sistema de pagos y consumo de APIs. Desarrollé el panel administrativo con Laravel Inertia y React, manteniendo una arquitectura modular y escalable.`,
    current: true,
  },
  {
    title: "Plataforma web de Cursos - Versión Inicial",
    company: "Freelance",
    period: "Septiembre 2025 - Octubre 2025",
    description: `Desarrollé la primera versión del proyecto como una plataforma educativa en Angular con Tailwind CSS, enfocada en la visualización de cursos y una interfaz responsiva basada en componentes reutilizables.`,
    current: true,
  },
  {
    title: "Desarrollador Fullstack",
    company: "DTI Consultores",
    period: "Enero 2025 - Abril 2025",
    description: `Desarrollé un sistema de reservas para hoteles con Angular y Laravel, incluyendo autenticación y gestión de disponibilidad. También creé una app fitness con Ionic para seguimiento de rutinas y progreso.`,
    current: false,
  },
  {
    title: "Desarrollador Fullstack (Practicante)",
    company: "dvinternet",
    period: "Mayo 2022 – Agosto 2022",
    description: `Desarrollé un sistema de gestión de clientes con Laravel y Angular, optimizando procesos internos. También creé la web corporativa mejorando la experiencia de usuario y presencia digital.`,
    current: false,
  },
];
---

<TimeLine >
    {
      experiences.map((exp) => (
        <div class="relative pl-12 md:pl-24  ">
          <div class="absolute left-2.5 md:left-6.5 top-0 flex items-center justify-center">
            {exp.current ? (
              <span class="relative flex size-4">
                <span class="absolute inline-flex h-full w-full rounded-full bg-primary ring-4 ring-primary/20 animate-ping" />
                <span class="relative inline-flex size-4 rounded-full bg-primary ring-4 ring-primary/20" />
              </span>
            ) : (
              <div class="size-4 rounded-full bg-primary ring-4 ring-primary/20" />
            )}
          </div>
          <Card class="p-6">
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-4 gap-2 ">
              <div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white leading-none">
                  {exp.title}
                </h3>
                <p class="text-primary font-semibold mt-1">{exp.company}</p>
              </div>
              <Badge>{exp.period}</Badge>
            </div>
            <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed whitespace-pre-line">
              {exp.description}
            </p>
          </Card>
        </div>
      ))
    }
</TimeLine>


